# Work Log Server — API 配置
# 复制此文件为 .work-log.env 并填入真实的 key
# cp .work-log.env.example .work-log.env

# DeepSeek API key (免费获取: https://platform.deepseek.com → API Keys)
DEEPSEEK_API_KEY=sk-your-key-here

# AI 模型 (可选, 默认 deepseek-chat)
WORK_LOG_AI_MODEL=deepseek-chat

# 每日自动总结时间 (可选, 默认 18:00)
WORK_LOG_SCHEDULE=18:00
