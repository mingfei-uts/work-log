# ============================================================
#  Work Log 配置示例
#  复制为 .work-log.env 后填入你自己的值:  cp .work-log.env.example .work-log.env
#  此文件可提交; .work-log.env 含密钥, 已被 .gitignore 忽略, 切勿提交。
# ============================================================

# --- AI 总结 (可选, 不填则 AI 功能禁用, 其余功能正常) ---

# 方案 A: DeepSeek (推荐, 中文好/便宜/有免费额度)
#   免费获取: https://platform.deepseek.com  →  API Keys
DEEPSEEK_API_KEY=sk-your-key-here
WORK_LOG_AI_MODEL=deepseek-chat
# WORK_LOG_AI_BASE=https://api.deepseek.com   # 默认值, 一般不用改

# 方案 B: OpenAI / 任意兼容 OpenAI 的服务 (取消注释并改 BASE)
#   OPENAI_API_KEY=sk-...
#   WORK_LOG_AI_BASE=https://api.openai.com
#   WORK_LOG_AI_MODEL=gpt-4o-mini

# --- 定时自动总结 (可选) ---
# 每天到点自动生成今日总结; 周五额外生成周报。HH:MM, 默认 18:00
WORK_LOG_SCHEDULE=18:00

# --- 路径 (可选, 默认基于脚本所在目录, 一般无需设置) ---
# 扫描哪个目录下的 git 仓库 (用于把当天 commit 关联进总结); 默认脚本目录
# WORK_LOG_REPOS_DIR=~/code

# Claude Code 会话记录目录 (用于 📥 CC 导入); 默认按 REPOS_DIR 自动推导
# WORK_LOG_CC_DIR=~/.claude/projects/-Users-you-code

# 服务端口 (默认 19878; PaaS 会用它注入的 $PORT)
# WORK_LOG_PORT=19878

# --- 公网部署才需要 (本地可忽略) ---
# 登录密码 — 一旦放公网【务必设置】, 否则任何人都能读写你的数据!
# WORK_LOG_PASSWORD=换成一个强密码
# WORK_LOG_USER=admin
# 绑定地址 — PaaS 检测到 $PORT 会自动用 0.0.0.0; 本地留空(=127.0.0.1 仅本机)
# WORK_LOG_HOST=0.0.0.0
